# Copy to .env and fill in your values:
#   cp .env.example .env

# App URLs — must match how you access the app in the browser (include port)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000

# Google Maps Platform — enable Places API & Geocoding API (Hong Kong region)
# Required for location autocomplete and Activity Map markers
GOOGLE_MAPS_API_KEY=

# DeepSeek — required for AI Chatbot (EduBot)
DEEPSEEK_API_KEY=

# Optional
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# JWT_SECRET=change-me-in-production

# Production deploy on EC2:
#   docker compose -f docker-compose.prod.yml up -d --build

# Local dev WITHOUT Docker only (Docker Compose injects these automatically)
# DATABASE_HOST=localhost
# DATABASE_USER=root
# DATABASE_PASSWORD=password
# DATABASE_NAME=skyline
