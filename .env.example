# Copy to .env and fill in your values:
#   cp .env.example .env

# App URLs — must match how you access the app in the browser (include port)
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
# Comma-separated browser origins allowed to call the API (include tunnel/custom domains)
# CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://your-domain.example.com
# ALLOWED_DEV_ORIGINS=your-domain.example.com

# Google Maps Platform — enable Places API & Geocoding API (Hong Kong region)
# Required for location autocomplete and Activity Map markers
GOOGLE_MAPS_API_KEY=

# DeepSeek — required for AI Chatbot (EduBot) and Content Studio
DEEPSEEK_API_KEY=

# Neo4j — graph database (Browser on :7474, Bolt on :7687)
# Use a strong password before exposing 7474 on a public subdomain.
# Generate one: openssl rand -base64 24
# NEO4J_USER is the app/Browser login; Docker bootstraps with "neo4j" + same password, then backend creates this user.
NEO4J_USER=skyline_admin
NEO4J_PASSWORD=change-me-to-a-strong-password
# Docker Compose injects NEO4J_URI=bolt://neo4j:7687 automatically for backend

# Set to 1 on production when restoring MySQL from dump (avoids re-importing dataset students).
# SKIP_LEARNING_IMPORT=1

# Optional
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# JWT_SECRET=change-me-in-production

# Production deploy on EC2:
#   docker compose -f docker-compose.prod.yml up -d --build

# Local dev WITHOUT Docker only (Docker Compose injects these automatically)
# DATABASE_HOST=localhost
# DATABASE_USER=root
# DATABASE_PASSWORD=password
# DATABASE_NAME=skyline
